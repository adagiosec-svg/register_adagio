# Neon PostgreSQL
# Neon 대시보드 > Connection Details에서 복사
DATABASE_URL="postgresql://user:password@ep-xxx.neon.tech/adagio?sslmode=require&pgbouncer=true"
DIRECT_URL="postgresql://user:password@ep-xxx.neon.tech/adagio?sslmode=require"

# 포탈 ID 암호화 키
# 생성법: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
PORTAL_ID_PEPPER="여기에_32바이트_랜덤_hex_64자"
PORTAL_ID_AES_KEY="여기에_32바이트_랜덤_hex_64자"

# 전화번호 암호화 키 (포탈 ID 키와 별도로 생성)
PHONE_AES_KEY="여기에_32바이트_랜덤_hex_64자"

# 민감정보 암호화 키 — 강사 계좌·연락처, 시스템 설정 계좌번호 암호화
# 생성법: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
SENSITIVE_AES_KEY="여기에_32바이트_랜덤_hex_64자"

# NextAuth
# 생성법: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
AUTH_SECRET="여기에_랜덤_시크릿"

# Pusher (https://pusher.com → 무료 Channels 앱 생성 후 복사)
PUSHER_APP_ID=""
NEXT_PUBLIC_PUSHER_KEY=""
PUSHER_SECRET=""
NEXT_PUBLIC_PUSHER_CLUSTER="ap3"

# Resend (https://resend.com → API Keys)
RESEND_API_KEY=""

# Vercel Cron Job 보안 토큰
# 생성법: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
CRON_SECRET="여기에_랜덤_시크릿"

# Studio Mate 연동 — 회원 프로필 링크 베이스 URL
# 예: https://studiomate.kr 이면 링크는 {URL}/member/{mateId} 형식으로 생성됩니다.
# 설정하지 않으면 링크가 비활성화됩니다.
NEXT_PUBLIC_STUDIOMATE_URL=""
